:: StoryScript [script]
var acc = document.getElementsByClassName("accordion");
var i;

for (i = 0; i < acc.length; i++) {
  acc[i].addEventListener("click", function() {
    /* Toggle between adding and removing the "active" class,
    to highlight the button that controls the panel */
    this.classList.toggle("active");

    /* Toggle between hiding and showing the active panel */
    var panel = this.nextElementSibling;
    if (panel.style.display === "block") {
      panel.style.display = "none";
    } else {
      panel.style.display = "block";
    }
  });
}

:: StoryStylesheet [stylesheet]

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');



/* ═══════════════════════════════════════════════════════════
   DESIGN TOKENS
   ═══════════════════════════════════════════════════════════ */
:root {
  /* Brand palette */
  --artuk-red:          #ff4b00;   /* Art UK signature red */
  --artuk-red-dark:     #750019;   /* Hover / pressed state */
  --artuk-red-light:    #ca002e;   /* Accent highlight */
  --artuk-red-pale:     #FDE8EE;   /* Tinted backgrounds */

  --artuk-header-bg:    #E8003D;   /* Header background */

  --artuk-black:        #1A1A1A;   /* Primary text */
  --artuk-charcoal:     #2D2D2D;   /* Secondary text */
  --artuk-mid-grey:     #9b938c;   /* Muted / metadata text */
  --artuk-light-grey:   #9b938c;   /* Dividers, borders */
  --artuk-off-white:    #F7F5F2;   /* Page background warm tint */
  --artuk-white:        #FFFFFF;
  --artuk-persian-blue: #174bc4;   /* buttons */
  --artuk-lilac:        #8080d0;   /* buttons */   
  --artuk-aquamarine:   #5affd3;   /* buttons */

  /* Typography */
  --font-sans: 'Graphik', 'Inter', -apple-system, BlinkMacSystemFont,
               'Segoe UI', Helvetica, Arial, sans-serif;

  /* Sizing scale */
  --text-xs:   0.75rem;
  --text-sm:   0.875rem;
  --text-base: 1rem;
  --text-md:   1.125rem;
  --text-lg:   1.25rem;
  --text-xl:   1.5rem;
  --text-2xl:  2rem;
  --text-3xl:  2.5rem;

  /* Spacing */
  --space-xs:  0.25rem;
  --space-sm:  0.5rem;
  --space-md:  1rem;
  --space-lg:  1.5rem;
  --space-xl:  2rem;
  --space-2xl: 3rem;

  /* Layout */
  --content-max-width: 720px;
  --header-height:     56px;

  /* Effects */
  --radius-sm:  2px;
  --radius-md:  4px;
  --shadow-sm:  0 1px 3px rgba(0,0,0,0.10);
  --shadow-md:  0 4px 12px rgba(0,0,0,0.12);
  --transition: 0.18s ease;
}


/* ═══════════════════════════════════════════════════════════
   RESET & BASE
   ═══════════════════════════════════════════════════════════ */
*, *::before, *::after {
  box-sizing: border-box;
}

html {
  font-size: 16px;
  -webkit-text-size-adjust: 100%;
  scroll-behavior: smooth;
}

body {
  margin: 0;
  padding: 0;
  background-color: var(--artuk-off-white);
  color: var(--artuk-black);
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: 400;
  line-height: 1.65;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}


/* ═══════════════════════════════════════════════════════════
   SUGARCUBE LAYOUT STRUCTURE
   ═══════════════════════════════════════════════════════════ */

/* Hide the default SugarCube UI bar entirely for a clean reading experience */
#ui-bar {
  display: none !important;
}

/* Main story area */
#story {
  margin: 0 auto;
  padding: 0;
}

/* The story title in the header region */
#story-title {
  display: none; /* We'll render the title within our custom header */
}

/* Passage container */
#passages {
  margin: 0 auto;
  max-width: var(--content-max-width);
  padding: var(--space-xl) var(--space-lg) var(--space-2xl);
}

/* Each passage */
.passage {
  background: var(--artuk-white);
  border: 1px solid var(--artuk-light-grey);
  border-radius: var(--radius-md);
  padding: var(--space-xl) var(--space-xl);
  box-shadow: var(--shadow-sm);
  position: relative;
}


/* ═══════════════════════════════════════════════════════════
   ART UK HEADER BAR
   ═══════════════════════════════════════════════════════════ */

/* Injected into the page via the StoryInit special passage or
   the PassageHeader special passage. Example markup:

   <header class="artuk-header">
     <a class="artuk-header__logo" href="javascript:Engine.play('Start')">
       <span class="artuk-header__logo-mark">Art UK</span>
     </a>
     <nav class="artuk-header__nav">
       <span class="artuk-header__nav-label">Your Story Title</span>
     </nav>
   </header>

   Add this to a passage named: PassageHeader
*/

.artuk-header {
  position: sticky;
  top: 0;
  z-index: 100;
  width: 100%;
  height: var(--header-height);
  background-color: var(--artuk-header-bg);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-lg);
  box-shadow: 0 2px 8px rgba(232, 0, 61, 0.30);
}

.artuk-header__logo {
  display: flex;
  align-items: center;
  text-decoration: none;
  gap: var(--space-sm);
}

.artuk-header__logo-mark {
  font-family: var(--font-sans);
  font-weight: 700;
  font-size: var(--text-lg);
  letter-spacing: -0.02em;
  color: var(--artuk-white);
  text-transform: uppercase;
}

.artuk-header__nav {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.artuk-header__nav-label {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 500;
  color: rgba(255,255,255,0.85);
  letter-spacing: 0.01em;
}


/* ═══════════════════════════════════════════════════════════
   TYPOGRAPHY
   ═══════════════════════════════════════════════════════════ */

.passage h1,
.passage h2,
.passage h3, 
.passage h4,
.passage h5,
.passage h6 {
  font-family: var(--font-sans);
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.02em;
  color: var(--artuk-black);
  margin-top: var(--space-xl);
  margin-bottom: var(--space-md);
}

.passage h1 { font-size: var(--text-2xl); margin-top: 0; }
.passage h2 { font-size: var(--text-xl);  }
.passage h3 { font-size: var(--text-lg); color: #ca002e; }
.passage h4 { font-size: var(--text-md);  }

.passage p {
  margin: 0 0 var(--space-md);
  color: var(--artuk-charcoal);
}

.passage p:last-child {
  margin-bottom: 0;
}

.passage p-breadcrumb {
  margin: 0 0 var(--space-md);
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: -0.02em;
  color: var(--mid-grey)
}

.passage strong, .passage b {
  font-weight: 600;
  color: var(--artuk-black);
}

.passage em, .passage i {
  font-style: italic;
}

.passage blockquote {
  margin: var(--space-lg) 0;
  padding: var(--space-md) var(--space-lg);
  border-left: 4px solid var(--artuk-red);
  background: var(--artuk-red-pale);
  color: var(--artuk-charcoal);
  font-style: italic;
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
}

.passage blockquote p {
  margin: 0;
}

.indented {
  padding-left: 1.5em;
}

.passage hr {
  border: none;
  border-top: 1px solid var(--artuk-light-grey);
  margin: var(--space-xl) 0;
}

.passage ul, .passage ol {
  padding-left: var(--space-lg);
  margin: 0 0 var(--space-md);
}

.passage li {
  margin-bottom: var(--space-xs);
  color: var(--artuk-charcoal);
}

.passage code {
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;
  font-size: var(--text-sm);
  background: var(--artuk-light-grey);
  padding: 2px 6px;
  border-radius: var(--radius-sm);
  color: var(--artuk-black);
}

.passage pre {
  background: var(--artuk-black);
  color: var(--artuk-off-white);
  padding: var(--space-md);
  border-radius: var(--radius-md);
  overflow-x: auto;
  font-size: var(--text-sm);
  line-height: 1.5;
  margin: var(--space-md) 0;
}

.passage pre code {
  background: none;
  padding: 0;
  color: inherit;
  font-size: inherit;
}


/* ═══════════════════════════════════════════════════════════
   LINKS (standard anchor + SugarCube <<link>> macro)
   ═══════════════════════════════════════════════════════════ */

.passage a,
.passage .link-internal,
.passage tw-link {
  color: var(--artuk-red);
  font-weight: 500;
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 3px;
  transition: color var(--transition),
              text-decoration-color var(--transition);
}

.passage a:hover,
.passage .link-internal:hover,
.passage tw-link:hover {
  color: var(--artuk-red-dark);
  text-decoration-thickness: 2px;
}

.passage a:focus-visible,
.passage .link-internal:focus-visible {
  outline: 2px solid var(--artuk-red);
  outline-offset: 2px;
  border-radius: var(--radius-sm);
}

/* Visited links — subtle desaturation */
.passage a:visited {
  color: var(--artuk-mid-grey);
}


/* ═══════════════════════════════════════════════════════════
   CHOICE / NAVIGATION LINKS
   Art UK style: clean list of options beneath passage text
   ═══════════════════════════════════════════════════════════ */

/* Container you can use: <div class="choices"> ... </div> */
.choices {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-xl);
  padding-top: var(--space-lg);
  border-top: 1px solid var(--artuk-light-grey);
}

.choices a,
.choices .link-internal {
  display: block;
  padding: var(--space-sm) var(--space-md);
  background: var(--artuk-white);
  border: 1.5px solid var(--artuk-red);
  border-radius: var(--radius-md);
  color: var(--artuk-red);
  font-weight: 600;
  font-size: var(--text-sm);
  text-decoration: none;
  letter-spacing: 0.01em;
  transition: background var(--transition), color var(--transition),
              border-color var(--transition), box-shadow var(--transition);
}

.choices a:hover,
.choices .link-internal:hover {
  background: var(--artuk-red);
  color: var(--artuk-white);
  box-shadow: var(--shadow-md);
  border-color: var(--artuk-red);
}

.choices a:active,
.choices .link-internal:active {
  background: var(--artuk-red-dark);
  border-color: var(--artuk-red-dark);
}

/* Primary CTA button style */
.btn-primary,
button.btn-primary {
  display: inline-block;
  padding: 0.65rem 1.5rem;
  background: var(--artuk-red);
  color: var(--artuk-white);
  font-family: var(--font-sans);
  font-weight: 600;
  font-size: var(--text-sm);
  letter-spacing: 0.02em;
  text-decoration: none;
  border: none;
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: background var(--transition), box-shadow var(--transition);
  box-shadow: 0 2px 6px rgba(232,0,61,0.25);
}

.btn-primary:hover {
  background: var(--artuk-red-dark);
  box-shadow: 0 4px 12px rgba(232,0,61,0.35);
  color: var(--artuk-white);
  text-decoration: none;
}


/* ═══════════════════════════════════════════════════════════
   SUGARCUBE BUILT-IN MACROS
   ═══════════════════════════════════════════════════════════ */

/* <<button>> macro */
.macro-button button,
button[data-passage] {
  display: inline-block;
  padding: 0.6rem 1.25rem;
  background: var(--artuk-red);
  color: var(--artuk-white);
  font-family: var(--font-sans);
  font-weight: 600;
  font-size: var(--text-sm);
  border: none;
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: background var(--transition);
  margin: var(--space-xs) var(--space-xs) var(--space-xs) 0;
}

.macro-button button:hover,
button[data-passage]:hover {
  background: var(--artuk-red-dark);
}

/* <<textbox>> / <<textarea>> macros */
.macro-textbox input[type='text'],
.macro-textarea textarea,
input.macro-textbox,
textarea.macro-textarea {
  width: 100%;
  padding: 0.5rem 0.75rem;
  font-family: var(--font-sans);
  font-size: var(--text-base);
  color: var(--artuk-black);
  background: var(--artuk-white);
  border: 1.5px solid var(--artuk-light-grey);
  border-radius: var(--radius-md);
  outline: none;
  transition: border-color var(--transition), box-shadow var(--transition);
}

.macro-textbox input[type='text']:focus,
.macro-textarea textarea:focus {
  border-color: var(--artuk-red);
  box-shadow: 0 0 0 3px rgba(232,0,61,0.15);
}

/* <<cycle>> and <<listbox>> macros */
.macro-cycle a,
.macro-listbox select {
  color: var(--artuk-red);
  font-weight: 500;
  cursor: pointer;
}

select.macro-listbox {
  padding: 0.4rem 0.75rem;
  border: 1.5px solid var(--artuk-light-grey);
  border-radius: var(--radius-md);
  background: var(--artuk-white);
  font-family: var(--font-sans);
  font-size: var(--text-base);
  color: var(--artuk-black);
  cursor: pointer;
  transition: border-color var(--transition);
}

select.macro-listbox:focus {
  border-color: var(--artuk-red);
  outline: none;
}

/* <<checkbox>> macro */
.macro-checkbox input[type='checkbox'] {
  accent-color: var(--artuk-red);
  width: 1rem;
  height: 1rem;
  cursor: pointer;
}

/* <<radiobutton>> macro */
.macro-radiobutton input[type='radio'] {
  accent-color: var(--artuk-red);
  width: 1rem;
  height: 1rem;
  cursor: pointer;
}


/* ═══════════════════════════════════════════════════════════
   DIALOGS & NOTIFICATIONS (SugarCube UI)
   ═══════════════════════════════════════════════════════════ */

#ui-dialog {
  font-family: var(--font-sans);
}

#ui-dialog-titlebar {
  background: var(--artuk-red);
  color: var(--artuk-white);
  font-weight: 700;
  letter-spacing: -0.01em;
}

#ui-dialog-titlebar button {
  color: var(--artuk-white);
}

#ui-dialog-body {
  background: var(--artuk-white);
  color: var(--artuk-charcoal);
  padding: var(--space-lg);
}


/* ═══════════════════════════════════════════════════════════
   PASSAGE TRANSITION ANIMATION
   ═══════════════════════════════════════════════════════════ */

/* Subtle fade-up on passage entry */
.passage {
  animation: passage-in 0.30s ease both;
}

@keyframes passage-in {
  from {
    opacity: 0;
    transform: translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}


/* ═══════════════════════════════════════════════════════════
   UTILITY CLASSES
   ═══════════════════════════════════════════════════════════ */

/* Artwork caption / metadata label */
.artuk-caption {
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--artuk-mid-grey);
}

/* Red rule / accent bar */
.artuk-rule {
  display: block;
  width: 40px;
  height: 3px;
  background: var(--artuk-red);
  margin: var(--space-md) 0;
  border: none;
}

/* Eyebrow label (red, uppercase) */
.artuk-eyebrow {
  display: block;
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--artuk-red);
  margin-bottom: var(--space-xs);
}

/* Art image block */
.artuk-artwork {
  width: 100%;
  margin: var(--space-lg) 0;
}

.artuk-artwork img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-md);
}

.artuk-artwork figcaption {
  font-size: var(--text-xs);
  color: var(--artuk-mid-grey);
  margin-top: var(--space-xs);
  font-weight: 400;
}

/* Info / callout box */
.artuk-callout {
  background: var(--artuk-red-pale);
  border-left: 4px solid var(--artuk-red);
  padding: var(--space-md) var(--space-lg);
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  margin: var(--space-lg) 0;
  font-size: var(--text-sm);
  color: var(--artuk-charcoal);
}

/* Progress indicator */
.artuk-progress {
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--artuk-mid-grey);
  margin-bottom: var(--space-lg);
}

.artuk-progress__bar {
  height: 2px;
  background: var(--artuk-light-grey);
  border-radius: 1px;
  margin-top: var(--space-xs);
  overflow: hidden;
}

.artuk-progress__fill {
  height: 100%;
  background: var(--artuk-red);
  border-radius: 1px;
  transition: width 0.4s ease;
}

/* Text alignment helpers */
.text-center { text-align: center; }
.text-right  { text-align: right;  }
.text-muted  { color: var(--artuk-mid-grey); }

/* Spacers */
.mt-0 { margin-top: 0; }
.mt-1 { margin-top: var(--space-sm); }
.mt-2 { margin-top: var(--space-md); }
.mt-3 { margin-top: var(--space-lg); }
.mt-4 { margin-top: var(--space-xl); }

.mb-0 { margin-bottom: 0; }
.mb-1 { margin-bottom: var(--space-sm); }
.mb-2 { margin-bottom: var(--space-md); }
.mb-3 { margin-bottom: var(--space-lg); }
.mb-4 { margin-bottom: var(--space-xl); }


/* ═══════════════════════════════════════════════════════════
   FOOTER
   ═══════════════════════════════════════════════════════════ */

/* Add this markup to a PassageFooter special passage:
   <footer class="artuk-footer">
     <span>Powered by <a href="https://artuk.org">Art UK</a></span>
   </footer>
*/

.artuk-footer {
  max-width: var(--content-max-width);
  margin: 0 auto;
  padding: var(--space-lg);
  text-align: center;
  font-size: var(--text-xs);
  color: var(--artuk-mid-grey);
  letter-spacing: 0.04em;
  border-top: 1px solid var(--artuk-light-grey);
}

.artuk-footer a {
  color: var(--artuk-red);
  text-decoration: none;
  font-weight: 500;
}

.artuk-footer a:hover {
  text-decoration: underline;
}


/* ═══════════════════════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════════════════════ */

@media (max-width: 600px) {
  #passages {
    padding: var(--space-md) var(--space-sm) var(--space-xl);
  }

  .passage {
    padding: var(--space-lg) var(--space-md);
  }

  .passage h1 { font-size: var(--text-xl); }
  .passage h2 { font-size: var(--text-lg); }

  .artuk-header {
    padding: 0 var(--space-md);
  }
}

@media (max-width: 400px) {
  .passage {
    padding: var(--space-md);
  }

  .choices a {
    font-size: var(--text-xs);
  }
}


/* ═══════════════════════════════════════════════════════════
   PRINT
   ═══════════════════════════════════════════════════════════ */

@media print {
  .artuk-header,
  .artuk-footer,
  .choices { display: none; }

  .passage {
    border: none;
    box-shadow: none;
    padding: 0;
  }

  body {
    background: white;
    color: black;
  }
}

/*
 * Art UK — Link Buttons
 * Add-on for artuk-sugarcube.css
 * SugarCube 2.37.3
 *
 * Append this to the bottom of artuk-sugarcube.css
 * (or paste into Story > Stylesheet after the main file).
 *
 * ─── WHAT THIS ADDS ──────────────────────────────────────────────────────────
 *
 *  Three button variants for use on [[links]] and <<link>> macros:
 *
 *    .btn-link           — solid red (primary action)
 *    .btn-link-outline   — white with red border (secondary action)
 *    .btn-link-ghost     — no border, red text (tertiary / low-emphasis)
 *
 *  A full-width stacked layout helper:
 *    .btn-link-group     — wraps multiple buttons in a vertical stack
 *
 *  Arrow variant (adds a › chevron):
 *    .btn-link.has-arrow
 *    .btn-link-outline.has-arrow
 *
 * ─── USAGE IN PASSAGES ───────────────────────────────────────────────────────
 *
 *  Inline [[wiki-style link]] as a button:
 *    <span class="btn-link">[[Go to the gallery|The Gallery]]</span>
 *
 *  <<link>> macro as a button:
 *    <<link "Enter the archive" "Archive Entrance">><<addclass "btn-link">><</link>>
 *    — OR, simpler, wrap it:
 *    <span class="btn-link"><<link "Enter the archive" "Archive Entrance">><</link>></span>
 *
 *  Stacked group (replaces the .choices div pattern):
 *    <div class="btn-link-group">
 *      <span class="btn-link">[[Examine the painting|Examine]]</span>
 *      <span class="btn-link-outline">[[Read the label|Label]]</span>
 *      <span class="btn-link-ghost">[[Walk away|Corridor]]</span>
 *    </div>
 *
 *  With arrow:
 *    <span class="btn-link has-arrow">[[Continue|Next Scene]]</span>
 *
 * ─────────────────────────────────────────────────────────────────────────────
 *
 * ─── SUGARCUBE JAVASCRIPT MACRO (optional) ───────────────────────────────────
 *
 *  Paste the following into Story > JavaScript to get a tidy <<linkbutton>> macro:
 *
 *    Macro.add('linkbutton', {
 *      handler: function () {
 *        var label   = this.args[0] || '';
 *        var target  = this.args[1] || '';
 *        var variant = this.args[2] || 'btn-link'; // btn-link | btn-link-outline | btn-link-ghost
 *        var arrow   = this.args[3] === true;
 *
 *        var cls = variant + (arrow ? ' has-arrow' : '');
 *        var $btn = jQuery('<span></span>').addClass(cls);
 *        var $a   = jQuery('<a></a>')
 *          .text(label)
 *          .attr('href', 'javascript:void(0)')
 *          .on('click', function () { Engine.play(target); });
 *
 *        $btn.append($a);
 *        $btn.appendTo(this.output);
 *      }
 *    });
 *
 *  Then in passages:
 *    <<linkbutton "Enter the archive" "Archive Entrance">>
 *    <<linkbutton "Read the label" "Label" "btn-link-outline">>
 *    <<linkbutton "Continue" "Next Scene" "btn-link" true>>
 *
 * ─────────────────────────────────────────────────────────────────────────────
 */


/* ═══════════════════════════════════════════════════════════
   SHARED BASE — all btn-link variants inherit this
   ═══════════════════════════════════════════════════════════ */

.btn-link,
.btn-link-outline,
.btn-link-ghost {
  /* Layout */
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
  width: 100%;          /* full-width by default for choice lists  */
  padding: 0.7rem 1rem 0.7rem 1.1rem;

  /* Typography */
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 600;
  letter-spacing: 0.01em;
  line-height: 1.3;
  text-decoration: none !important;

  /* Shape */
  border-radius: var(--radius-md);
  border: 1.5px solid transparent;
  cursor: pointer;
  position: relative;
  overflow: hidden;

  /* Motion */
  transition:
    background     0.16s ease,
    color          0.16s ease,
    border-color   0.16s ease,
    box-shadow     0.16s ease,
    transform      0.12s ease;
}

/* Strip default anchor styles from any <a> inside a btn-link span */
.btn-link a,
.btn-link-outline a,
.btn-link-ghost a,
.btn-link .link-internal,
.btn-link-outline .link-internal,
.btn-link-ghost .link-internal {
  color: inherit !important;
  text-decoration: none !important;
  font-weight: inherit !important;
  display: contents; /* make the <a> invisible to layout — the span is the button */
}

/* Visited state — don't grey-out buttons */
.btn-link a:visited,
.btn-link-outline a:visited,
.btn-link-ghost a:visited {
  color: inherit !important;
}

/* Keyboard focus ring */
.btn-link:focus-visible,
.btn-link-outline:focus-visible,
.btn-link-ghost:focus-visible,
.btn-link a:focus-visible,
.btn-link-outline a:focus-visible,
.btn-link-ghost a:focus-visible {
  outline: 2px solid var(--artuk-red);
  outline-offset: 3px;
  border-radius: var(--radius-md);
}

/* Press feedback */
.btn-link:active,
.btn-link-outline:active,
.btn-link-ghost:active {
  transform: translateY(1px);
}


/* ═══════════════════════════════════════════════════════════
   VARIANT 1 — Solid red  (.btn-link)
   Primary navigation / main choice
   ═══════════════════════════════════════════════════════════ */

.btn-link {
  background:   var(--artuk-red);
  color:        var(--artuk-white);
  border-color: var(--artuk-red);
  box-shadow:   0 2px 6px rgba(232, 0, 61, 0.20);
}

.btn-link:hover {
  background:   var(--artuk-red-dark);
  border-color: var(--artuk-red-dark);
  box-shadow:   0 4px 14px rgba(232, 0, 61, 0.32);
  color:        var(--artuk-white);
}

.btn-link:active {
  background:   var(--artuk-red-dark);
  box-shadow:   none;
}


/* ═══════════════════════════════════════════════════════════
   VARIANT 2 — Outline  (.btn-link-outline)
   Secondary choice / alternative path
   ═══════════════════════════════════════════════════════════ */

.btn-link-outline {
  background:   var(--artuk-persian-blue);
  color:        var(--artuk-white);
  border-color: var(--artuk-persian-blue);
}

.btn-link-outline:hover {
  background:   var(--artuk-lilac);
  border-color: var(--artuk-white);
  color:        var(--artuk-black);
  box-shadow:   0 2px 8px rgba(232, 0, 61, 0.12);
}

.btn-link-outline:active {
  background: var(--artuk-red-pale);
}


/* ═══════════════════════════════════════════════════════════
   VARIANT 3 — Ghost  (.btn-link-ghost)
   Tertiary / low-emphasis (e.g. "go back", "skip")
   ═══════════════════════════════════════════════════════════ */

.btn-link-ghost {
  background:   transparent;
  color:        var(--artuk-charcoal);
  border-color: var(--artuk-mid-grey);
  font-weight:  500;
}

.btn-link-ghost:hover {
  background:   var(--artuk-off-white);
  color:        var(--artuk-persian-blue);
  border-color: var(--artuk-persian-blue);
}

.btn-link-ghost:active {
  background: var(--artuk-light-grey);
}


/* ═══════════════════════════════════════════════════════════
   ARROW MODIFIER  (.has-arrow)
   Appends a › chevron to the right edge
   Works on any variant: .btn-link.has-arrow etc.
   ═══════════════════════════════════════════════════════════ */

.has-arrow::after {
  content: '';
  display: inline-block;
  flex-shrink: 0;
  width:  7px;
  height: 7px;
  border-right: 2px solid currentColor;
  border-top:   2px solid currentColor;
  transform: rotate(45deg) translate(-1px, 1px);
  opacity: 0.8;
  transition: transform 0.14s ease, opacity 0.14s ease;
}

.has-arrow:hover::after {
  transform: rotate(45deg) translate(1px, -1px);
  opacity: 1;
}


/* ═══════════════════════════════════════════════════════════
   STACKED GROUP  (.btn-link-group)
   Wraps multiple button-links in a vertical choice list.
   Replaces the older .choices pattern (both still work).
   ═══════════════════════════════════════════════════════════ */

.btn-link-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-xl);
  padding-top: var(--space-lg);
  border-top: 1px solid var(--artuk-light-grey);
}

/* Optional label above the group */
.btn-link-group__label {
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--artuk-mid-grey);
  margin-bottom: var(--space-xs);
}

/* Inline (side-by-side) variant */
.btn-link-group--inline {
  flex-direction: row;
  flex-wrap: wrap;
}

.btn-link-group--inline .btn-link,
.btn-link-group--inline .btn-link-outline,
.btn-link-group--inline .btn-link-ghost {
  width: auto;        /* shrink to content in row layout */
  flex: 0 1 auto;
}


/* ═══════════════════════════════════════════════════════════
   INLINE (non-group) BUTTON
   When you want a button that doesn't stretch full-width —
   add .btn-link--inline to the span.
   ═══════════════════════════════════════════════════════════ */

.btn-link--inline,
.btn-link-outline--inline,
.btn-link-ghost--inline {
  width: auto;
  display: inline-flex;
}


/* ═══════════════════════════════════════════════════════════
   DISABLED STATE
   Add [disabled] attribute or .is-disabled class
   ═══════════════════════════════════════════════════════════ */

.btn-link.is-disabled,
.btn-link-outline.is-disabled,
.btn-link-ghost.is-disabled,
.btn-link[disabled],
.btn-link-outline[disabled],
.btn-link-ghost[disabled] {
  opacity: 0.4;
  pointer-events: none;
  cursor: not-allowed;
  box-shadow: none;
}


/* ═══════════════════════════════════════════════════════════
   OVERRIDE — stop .passage a rules interfering
   The base stylesheet styles .passage a with underline/red.
   These selectors are more specific so they win cleanly.
   ═══════════════════════════════════════════════════════════ */

.passage .btn-link a,
.passage .btn-link-outline a,
.passage .btn-link-ghost a,
.passage .btn-link .link-internal,
.passage .btn-link-outline .link-internal,
.passage .btn-link-ghost .link-internal {
  color:           inherit !important;
  text-decoration: none !important;
  font-weight:     inherit !important;
  border-bottom:   none !important;
}

.passage .btn-link a:visited,
.passage .btn-link-outline a:visited,
.passage .btn-link-ghost a:visited {
  color: inherit !important;
}


/* ═══════════════════════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════════════════════ */

@media (max-width: 600px) {
  .btn-link,
  .btn-link-outline,
  .btn-link-ghost {
    padding: 0.65rem 0.9rem 0.65rem 1rem;
    font-size: var(--text-xs);
  }

  /* Inline group wraps to full-width on small screens */
  .btn-link-group--inline .btn-link,
  .btn-link-group--inline .btn-link-outline,
  .btn-link-group--inline .btn-link-ghost {
    width: 100%;
  }
}

/* ═══════════════════════════════════════════════════════════
   DETAILS FOR ACCORDION TO GO HERE - https://dev.to/whitep4nth3r/how-to-build-an-html-only-accordion-no-javascript-required-4jc4
   ═══════════════════════════════════════════════════════════ */



/* ═══════════════════════════════════════════════════════════
   PRINT
   ═══════════════════════════════════════════════════════════ */

@media print {
  .btn-link,
  .btn-link-outline,
  .btn-link-ghost {
    background: none !important;
    color: black !important;
    border: 1px solid #999 !important;
    box-shadow: none !important;
  }

  .has-arrow::after {
    display: none;
  }
}